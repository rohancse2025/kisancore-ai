# KisanCore Backend - Environmental Variables
APP_NAME=kisancore-ai
ENVIRONMENT=dev
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,*

# AI & Weather
GROQ_API_KEY=your_groq_key_here
OPENWEATHER_API_KEY=your_weather_key_here

# SMS (Twilio Standard SMS - FREE TRIAL)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_SMS_FROM=+15005550006

# ─── WhatsApp (Twilio Sandbox — FREE, works with Indian numbers) ──────────────
# Uses same TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN
# Setup: twilio.com/console → Messaging → Try WhatsApp → Send message to sandbox
# Set webhook: YOUR_NGROK_URL/api/v1/sms/webhook in sandbox settings
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
